# Create an API client at https://www.warcraftlogs.com/api/clients/
# The redirect URL below must be listed on that client — it is where Warcraft
# Logs sends people back to after they sign in.
# Real values go in .env (which is gitignored) — NEVER in this file, which is
# committed.
WCL_CLIENT_ID=
WCL_CLIENT_SECRET=
WCL_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Signs the session cookie. Any long random string; changing it signs everyone
# out. Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
